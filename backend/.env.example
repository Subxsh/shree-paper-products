# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/shree_paper_products

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Admin Credentials (Change in production)
ADMIN_EMAIL=admin@shreepaper.com
ADMIN_PASSWORD=admin123

# Email Configuration (for custom order notifications)
# Use Google App Password: https://support.google.com/accounts/answer/185833
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_digit_app_password
ADMIN_EMAILS=admin@shreepaper.com,orders@shreepaper.com
